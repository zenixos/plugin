#!/usr/bin/env nu
# description: Sync skill modules and imports

use lib/plugin-config.nu *
use lib/plugin-discover.nu
use ../lib/symlink.nu

const VERIFY_SCRIPT = (path self | path dirname | path join "verify.nu")

# ── Generation ──

def gen-mod [skill: record] {
    if ($skill.commands | is-empty) { return }

    let use_lines = ($skill.commands | each {|f| $"export use ($f | path basename)" })

    let header = [
        "# auto-generated by plugin sync"
        "use ../lib/help.nu"
        "const SKILL_DIR = (path self | path dirname)"
        $"# ($skill.description)"
        $"export def main [] { help show ($skill.name) $SKILL_DIR }"
        ""
    ]

    ($header | append $use_lines | append "" | str join "\n")
    | save -f ($skill.dir | path join "mod.nu")
}

# Sync skill modules and imports
export def main [] {
    let skills = plugin-discover | where has_mod

    $skills | each {|s| symlink data $s.dir }
    $skills | each {|s| gen-mod $s }
    $skills | each {|s| $"use ($s.name)" } | str join "\n\n" | save -f $LOAD_FILE

    exec nu --env-config $ENV_FILE $VERIFY_SCRIPT
}
